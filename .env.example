# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Database Configuration
DATABASE_URL=postgresql://postgres:password@db:5432/receipt_analyzer
# For local development with SQLite (optional):
# DATABASE_URL=sqlite:///./receipt_analyzer.db

# Application Configuration
APP_PORT=8000
DEBUG=false

# Storage Configuration
STORAGE_VOLUME_PATH=/app/storage_volume
TEMP_STORAGE_PATH=/app/storage
